# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated, leave empty to allow all)
# Get your ID by messaging @userinfobot
ALLOWED_USER_IDS=123456789,987654321

# Default working directory for Claude Code
WORKING_DIR=/Users/yourname

# Claude CLI path (leave empty to use system PATH)
CLAUDE_PATH=

# Open Claude Code window on bot startup (true/false)
OPEN_CLAUDE_ON_START=false
